# Episode 6 — Guardrails & Safety
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# Then add your keys. NEVER commit the real .env file.

# Set EITHER ONE of these two (not both required) — llm_provider.py picks the
# provider automatically from whichever key is present. If you set both,
# OPENAI_API_KEY wins by default; force a choice with LLM_PROVIDER below.
# See README.md "Choose a provider" for how to get either key.
OPENAI_API_KEY=sk-...your-openai-key-here...
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key-here...

# Optional: force a provider when both keys above are set ("openai" or "anthropic").
LLM_PROVIDER=

# Optional: override the default model for whichever provider is active
# (defaults: gpt-4.1 for OpenAI, claude-sonnet-4-6 for Anthropic).
LLM_MODEL=

# Optional: auto-approve risky actions in the TERMINAL demo only (CLI, not the
# web UI — the web UI always asks a real human via the Approve/Deny button).
# Leave unset. Setting this to 1 defeats the whole point of the episode.
AUTO_APPROVE=
